generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  password      String
  role          String   @default("SEEKER")
  status        String   @default("ACTIVE")
  emailVerified Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  jobSeekerProfile    JobSeekerProfile?
  employerProfile     EmployerProfile?
  freelancerProfile   FreelancerProfile?

  jobsPosted           Job[] @relation("EmployerPostedJobs")
  adminPostedJobs      Job[] @relation("AdminPostedJobs")
  applications         Application[]
  freelanceServices    FreelanceService[]

  messagesSent         Message[] @relation("SentMessages")
  conversationsAsUser1 Conversation[] @relation("ConversationUser1")
  conversationsAsUser2 Conversation[] @relation("ConversationUser2")

  cvGenerations        CVGeneration[]
  reportsSubmitted     Report[] @relation("Reporter")
  reportsReceived      Report[] @relation("ReportedUser")
  serviceRequestsSent  ServiceRequest[] @relation("ServiceRequestClient")
  employerAgreements   Agreement[] @relation("EmployerAgreements")
  seekerAgreements     Agreement[] @relation("SeekerAgreements")
  freelancerAgreements Agreement[] @relation("FreelancerAgreements")
  clientAgreements     Agreement[] @relation("ClientAgreements")
  agreementEvents      AgreementEvent[]
  proposalsCreated     Proposal[] @relation("ProposalCreator")
  proposalsReceived    Proposal[] @relation("ProposalRecipient")
  proposalRevisions    ProposalRevision[] @relation("ProposalRevisionAuthor")
  notifications        Notification[]
  paymentsSent         Payment[] @relation("PaymentPayer")
  paymentsReceived     Payment[] @relation("PaymentPayee")
  reviewsWritten       Review[] @relation("ReviewAuthor")
  reviewsReceived      Review[] @relation("ReviewRecipient")
  disputesCreated      AgreementDispute[] @relation("DisputeCreator")
  disputesReceived     AgreementDispute[] @relation("DisputeCounterparty")
  disputesResolved     AgreementDispute[] @relation("DisputeResolver")
  verificationRequests VerificationRequest[] @relation("VerificationRequester")
  verificationReviews  VerificationRequest[] @relation("VerificationReviewer")
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]

  @@index([role])
  @@index([status])
  @@index([createdAt])
}

model JobSeekerProfile {
  id            String   @id @default(uuid())
  userId        String   @unique
  firstName     String?
  lastName      String?
  skills        String   @default("")
  experience    String?
  resumeFileUrl String?
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model EmployerProfile {
  id          String   @id @default(uuid())
  userId      String   @unique
  companyName String
  industry    String?
  logoUrl     String?
  website     String?
  description String?
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model FreelancerProfile {
  id           String   @id @default(uuid())
  userId       String   @unique
  firstName    String?
  lastName     String?
  hourlyRate   Float?
  portfolioUrl String?
  bio          String?
  skills       String   @default("")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Job {
  id           String   @id @default(uuid())
  employerId   String
  postedByAdminId String?
  postedByAdminAt DateTime?
  title        String
  description  String
  location     String?
  type         String
  salary       String?
  category     String?
  status       String   @default("ACTIVE")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  employer     User          @relation("EmployerPostedJobs", fields: [employerId], references: [id], onDelete: Cascade)
  postedByAdmin User?        @relation("AdminPostedJobs", fields: [postedByAdminId], references: [id], onDelete: SetNull)
  applications Application[]
  reports      Report[]      @relation("ReportedJob")

  @@index([employerId])
  @@index([postedByAdminId])
  @@index([status])
  @@index([category])
  @@index([postedByAdminAt])
  @@index([createdAt])
}

model Application {
  id          String    @id @default(uuid())
  jobId       String
  seekerId    String
  coverLetter String?
  status      String    @default("SUBMITTED")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  job         Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  seeker      User      @relation(fields: [seekerId], references: [id], onDelete: Cascade)
  agreement   Agreement?
  proposals   Proposal[]

  @@unique([jobId, seekerId])
  @@index([jobId, status])
  @@index([seekerId])
  @@index([status])
  @@index([createdAt])
}

model FreelanceService {
  id              String   @id @default(uuid())
  freelancerId    String
  title           String
  description     String
  price           Float
  deliveryTime    String?
  category        String?
  status          String   @default("ACTIVE")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  freelancer      User             @relation(fields: [freelancerId], references: [id], onDelete: Cascade)
  reports         Report[]         @relation("ReportedService")
  serviceRequests ServiceRequest[]

  @@index([freelancerId])
  @@index([status])
  @@index([category])
  @@index([createdAt])
}

model ServiceRequest {
  id        String   @id @default(uuid())
  serviceId String
  clientId  String
  message   String
  budget    String?
  timeline  String?
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  service   FreelanceService @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  client    User             @relation("ServiceRequestClient", fields: [clientId], references: [id], onDelete: Cascade)
  agreement Agreement?
  proposals Proposal[]

  @@index([serviceId])
  @@index([clientId])
  @@index([status])
  @@index([createdAt])
}

model Proposal {
  id               String   @id @default(uuid())
  applicationId    String?
  serviceRequestId String?
  creatorId        String
  recipientId      String
  type             String
  status           String   @default("PENDING")
  title            String
  summary          String
  amount           String?
  timeline         String?
  expiresAt        DateTime?
  acceptedAt       DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  application    Application?    @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  serviceRequest ServiceRequest? @relation(fields: [serviceRequestId], references: [id], onDelete: Cascade)
  creator        User            @relation("ProposalCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  recipient      User            @relation("ProposalRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  revisions      ProposalRevision[]

  @@index([applicationId])
  @@index([serviceRequestId])
  @@index([creatorId])
  @@index([recipientId])
  @@index([status])
  @@index([updatedAt])
  @@index([expiresAt])
}

model ProposalRevision {
  id         String   @id @default(uuid())
  proposalId String
  authorId   String
  summary    String
  amount     String?
  timeline   String?
  message    String?
  createdAt  DateTime @default(now())

  proposal Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  author   User     @relation("ProposalRevisionAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([proposalId, createdAt])
  @@index([authorId])
}

model Agreement {
  id               String   @id @default(uuid())
  type             String
  title            String
  summary          String?
  amount           String?
  status           String   @default("ACTIVE")
  applicationId    String?  @unique
  serviceRequestId String?  @unique
  employerId       String?
  seekerId         String?
  freelancerId     String?
  clientId         String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  application    Application?    @relation(fields: [applicationId], references: [id], onDelete: SetNull)
  serviceRequest ServiceRequest? @relation(fields: [serviceRequestId], references: [id], onDelete: SetNull)
  employer       User?           @relation("EmployerAgreements", fields: [employerId], references: [id], onDelete: SetNull)
  seeker         User?           @relation("SeekerAgreements", fields: [seekerId], references: [id], onDelete: SetNull)
  freelancer     User?           @relation("FreelancerAgreements", fields: [freelancerId], references: [id], onDelete: SetNull)
  client         User?           @relation("ClientAgreements", fields: [clientId], references: [id], onDelete: SetNull)
  events         AgreementEvent[]
  milestones     AgreementMilestone[]
  payments       Payment[]
  reviews        Review[]
  disputes       AgreementDispute[]

  @@index([status])
  @@index([createdAt])
  @@index([employerId])
  @@index([seekerId])
  @@index([freelancerId])
  @@index([clientId])
}

model Review {
  id         String   @id @default(uuid())
  agreementId String
  reviewerId String
  revieweeId String
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  agreement  Agreement @relation(fields: [agreementId], references: [id], onDelete: Cascade)
  reviewer   User      @relation("ReviewAuthor", fields: [reviewerId], references: [id], onDelete: Cascade)
  reviewee   User      @relation("ReviewRecipient", fields: [revieweeId], references: [id], onDelete: Cascade)

  @@unique([agreementId, reviewerId])
  @@index([revieweeId, createdAt])
  @@index([reviewerId, createdAt])
  @@index([rating])
}

model AgreementDispute {
  id             String   @id @default(uuid())
  agreementId    String
  creatorId      String
  counterpartyId String?
  resolverId     String?
  type           String   // PAYMENT, DELIVERY, QUALITY, COMMUNICATION, OTHER
  status         String   @default("OPEN") // OPEN, UNDER_REVIEW, RESOLVED, DISMISSED
  title          String
  description    String
  evidenceUrl    String?
  resolutionNote String?
  resolvedAt     DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  agreement      Agreement @relation(fields: [agreementId], references: [id], onDelete: Cascade)
  creator        User      @relation("DisputeCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  counterparty   User?     @relation("DisputeCounterparty", fields: [counterpartyId], references: [id], onDelete: SetNull)
  resolver       User?     @relation("DisputeResolver", fields: [resolverId], references: [id], onDelete: SetNull)

  @@index([agreementId, createdAt])
  @@index([creatorId, createdAt])
  @@index([counterpartyId, createdAt])
  @@index([resolverId, createdAt])
  @@index([status, createdAt])
  @@index([type, status])
}

model VerificationRequest {
  id          String   @id @default(uuid())
  userId      String
  reviewerId  String?
  type        String
  status      String   @default("PENDING")
  details     String
  documentUrl String?
  reviewNote  String?
  internalNote String?
  reviewedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation("VerificationRequester", fields: [userId], references: [id], onDelete: Cascade)
  reviewer    User?    @relation("VerificationReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([reviewerId, createdAt])
  @@index([status, createdAt])
  @@index([type, status])
}

model AgreementEvent {
  id         String   @id @default(uuid())
  agreementId String
  actorId    String?
  eventType  String
  message    String
  fromStatus String?
  toStatus   String?
  createdAt  DateTime @default(now())

  agreement  Agreement @relation(fields: [agreementId], references: [id], onDelete: Cascade)
  actor      User?     @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([agreementId, createdAt])
  @@index([actorId])
}

model AgreementMilestone {
  id                 String   @id @default(uuid())
  agreementId        String
  title              String
  description        String?
  amount             String?
  dueDate            DateTime?
  status             String   @default("PENDING")
  paymentStatus      String   @default("PENDING")
  paymentRequestedAt DateTime?
  paidAt             DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  agreement          Agreement @relation(fields: [agreementId], references: [id], onDelete: Cascade)
  payments           Payment[]

  @@index([agreementId])
  @@index([status])
  @@index([paymentStatus])
  @@index([dueDate])
}

model Payment {
  id            String   @id @default(uuid())
  agreementId   String
  milestoneId   String
  payerId       String
  payeeId       String
  provider      String   @default("SANDBOX")
  status        String   @default("PENDING")
  amount        String
  currency      String?
  providerAmount Int?
  reference     String   @unique
  checkoutUrl   String?
  failureReason String?
  completedAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  agreement     Agreement          @relation(fields: [agreementId], references: [id], onDelete: Cascade)
  milestone     AgreementMilestone @relation(fields: [milestoneId], references: [id], onDelete: Cascade)
  payer         User               @relation("PaymentPayer", fields: [payerId], references: [id], onDelete: Cascade)
  payee         User               @relation("PaymentPayee", fields: [payeeId], references: [id], onDelete: Cascade)

  @@index([agreementId, createdAt])
  @@index([milestoneId, createdAt])
  @@index([payerId])
  @@index([payeeId])
  @@index([status])
  @@index([createdAt])
}

model Conversation {
  id        String   @id @default(uuid())
  user1Id   String
  user2Id   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user1     User      @relation("ConversationUser1", fields: [user1Id], references: [id], onDelete: Cascade)
  user2     User      @relation("ConversationUser2", fields: [user2Id], references: [id], onDelete: Cascade)
  messages  Message[]

  @@index([user1Id])
  @@index([user2Id])
  @@index([updatedAt])
}

model Message {
  id             String   @id @default(uuid())
  conversationId String
  senderId       String
  content        String?
  attachmentUrl  String?
  attachmentName String?
  attachmentContentType String?
  attachmentSizeBytes Int?
  read           Boolean  @default(false)
  createdAt      DateTime @default(now())

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([senderId])
  @@index([read])
}

model CVGeneration {
  id        String   @id @default(uuid())
  userId    String
  prompt    String?
  content   String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String
  title     String
  message   String
  actionUrl String?
  read      Boolean  @default(false)
  readAt    DateTime?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read, createdAt])
  @@index([type])
}

model Report {
  id             String   @id @default(uuid())
  reporterId     String
  jobId          String?
  serviceId      String?
  reportedUserId String?
  reason         String
  status         String   @default("PENDING")
  createdAt      DateTime @default(now())

  reporter       User              @relation("Reporter", fields: [reporterId], references: [id], onDelete: Cascade)
  job            Job?              @relation("ReportedJob", fields: [jobId], references: [id], onDelete: SetNull)
  service        FreelanceService? @relation("ReportedService", fields: [serviceId], references: [id], onDelete: SetNull)
  reportedUser   User?             @relation("ReportedUser", fields: [reportedUserId], references: [id], onDelete: SetNull)

  @@index([reporterId])
  @@index([jobId])
  @@index([serviceId])
  @@index([reportedUserId])
  @@index([status])
  @@index([createdAt])
}

model EmailVerificationToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  token     String    @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model EmailVerificationToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  token     String    @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}
